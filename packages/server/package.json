{
  "name": "@colobot/server",
  "version": "0.1.0",
  "description": "ColoBot 完整服务整合包",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "colobot": "dist/cli.js"
  },
  "exports": {
    ".": {
