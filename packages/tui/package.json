{
  "name": "@colobot/tui",
  "version": "0.1.0",
  "description": "ColoBot 终端界面",
  "license": "AGPL-3.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "colobot": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && cp src/cli.js dist/cli.js",
    "dev": "tsc --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@colobot/core": "*",
    "@colobot/types": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}