# ColoBot Environment Variables

# LLM Provider
LLM_PROVIDER=openai|anthropic|minimax
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key
MINIMAX_API_KEY=your_minimax_key

# SearXNG
SEARXNG_URL=http://127.0.0.1:8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=colobot
DB_USER=colonies
DB_PASSWORD=your_password

# Feishu / Lark App Bot（方案 B - 交互式卡片，需公网回调）
LARK_APP_ID=cli_xxxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxx
LARK_VERIFICATION_TOKEN=xxxxxxxx        # 事件订阅验签 Token（可选）
FEISHU_APPROVER_OPEN_ID=ou_xxxxxxxx      # 审批员飞书 open_id
COLOBOT_PUBLIC_URL=https://your-domain.com  # 公网回调地址

# Feishu Webhook（方案 A - 兼容旧版，仅单向推送）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx

# 通用消息发送（send_message 工具，webhook 渠道）
MESSAGE_WEBHOOK_URL=https://example.com/webhook

# 邮件发送（send_message 工具，email 渠道）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_password
SMTP_TO=recipient@example.com
SMTP_FROM=your@email.com

# Telegram 通知（send_message 工具，telegram 渠道）
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=987654321

# Dashboard Login Key (leave empty to disable login page, set a value to enable)
COLOBOT_API_KEY=your_api_key_here

# Ports
COLOBOT_PORT=18792

# Additional API Keys for multi-key auth (comma-separated)
# Or use --api-keys CLI flag at startup
# Or use interactive input at startup
