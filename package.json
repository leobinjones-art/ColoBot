{
  "name": "colobot-monorepo",
  "version": "0.2.0",
  "description": "单智能体 + 子智能体协作平台 — 多模态 AI + Skill 编排 + SearXNG 搜索",
  "license": "Apache-2.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "release": "release-please release",
    "dev": "tsx watch src/colobot-server.ts",
    "build": "tsc",
    "build:packages": "npm run build -ws",
    "start": "node dist/colobot-server.js",
    "db:init": "psql -U colobot -d colobot < sql/schema.sql",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --max-warnings 200",
    "test:e2e": "vitest run src/__tests__/e2e.test.ts",
    "test:e2e:watch": "vitest src/__tests__/e2e.test.ts"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "dotenv": "^16.4.5",
    "llm-guard": "^0.1.8",
    "pg": "^8.13.0",
    "pgvector": "^0.2.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.12",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^10.2.1",
    "msw": "^2.13.4",
    "release-please": "^17.6.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
